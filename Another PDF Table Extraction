class PDFTableExtractor:
    """
    Main extractor that coordinates the entire pipeline
    """
    
    def __init__(self, config: ExtractionConfig = None):
        self.config = config or ExtractionConfig()
        self.extractor = HybridTableExtractor(self.config)
    
    def extract(self, pdf_path: str, output_dir: str = "extracted_tables") -> Dict[str, Any]:
        """
        Extract all tables from PDF and save to output directory
        
        Args:
            pdf_path: Path to PDF file
            output_dir: Directory to save extracted tables
        
        Returns:
            Dictionary with extraction results and metadata
        """
        pdf_path = Path(pdf_path)
        output_dir = Path(output_dir)
        output_dir.mkdir(exist_ok=True)
        
        # Extract all tables
        tables = self.extractor.extract_all_tables(pdf_path)
        
        # Save results
        results = {
            'source': str(pdf_path),
            'total_tables': len(tables),
            'tables': [],
            'metadata': {
                'config': {
                    'min_confidence': self.config.min_confidence,
                    'detect_merged_cells': self.config.detect_merged_cells,
                    'preserve_headers': self.config.preserve_headers,
                }
            }
        }
        
        for idx, table in enumerate(tables):
            table_info = {
                'index': idx,
                'shape': table.shape,
                'columns': table.columns.tolist() if hasattr(table, 'columns') else [],
            }
            results['tables'].append(table_info)
            
            # Save to requested formats
            base_name = f"table_{idx + 1}"
            
            if 'csv' in self.config.output_formats:
                table.to_csv(output_dir / f"{base_name}.csv", index=False)
            
            if 'excel' in self.config.output_formats:
                table.to_excel(output_dir / f"{base_name}.xlsx", index=False)
            
            if 'json' in self.config.output_formats:
                table.to_json(output_dir / f"{base_name}.json", orient='records', indent=2)
            
            print(f"  ✓ Table {idx + 1}: {table.shape[0]} rows × {table.shape[1]} cols")
        
        # Save summary report
        summary_path = output_dir / f"extraction_summary.json"
        with open(summary_path, 'w') as f:
            json.dump(results, f, indent=2)
        
        print(f"\n✅ Extraction complete! {len(tables)} tables saved to {output_dir}")
        
        return results


