def example_batch_process():
    """Process multiple PDFs in batch"""
    pdf_folder = Path("pdfs")
    config = ExtractionConfig(output_formats=['csv'])
    
    all_results = {}
    
    for pdf_path in pdf_folder.glob("*.pdf"):
        print(f"\n{'='*50}")
        extractor = PDFTableExtractor(config)
        results = extractor.extract(pdf_path, output_dir=f"output/{pdf_path.stem}")
        all_results[pdf_path.name] = results
    
    return all_results


