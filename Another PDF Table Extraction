class HybridTableExtractor:
    """
    Combines multiple extraction strategies for optimal results
    Uses OpenDataLoader's hybrid AI + heuristic approach [citation:6][citation:9]
    Falls back to classical methods when needed
    """
    
    def __init__(self, config: ExtractionConfig = None):
        self.config = config or ExtractionConfig()
        self.spartan_detector = SpartanTableDetector()
        self.extraction_stats = []
    
    def extract_all_tables(self, pdf_path: str) -> List[pd.DataFrame]:
        """
        Extract all tables from PDF using multi-strategy approach
        """
        pdf_path = Path(pdf_path)
        all_tables = []
        
        print(f"📄 Processing: {pdf_path.name}")
        
        # Strategy 1: OpenDataLoader (if available) - best overall
        tables = self._extract_opendataloader(pdf_path)
        if tables:
            print(f"  ✓ OpenDataLoader: {len(tables)} tables")
            all_tables.extend(tables)
        
        # Strategy 2: Camelot lattice - best for bordered tables
        tables = self._extract_camelot_lattice(pdf_path)
        if tables:
            print(f"  ✓ Camelot (lattice): {len(tables)} tables")
            all_tables.extend(tables)
        
        # Strategy 3: Camelot stream - best for borderless tables
        tables = self._extract_camelot_stream(pdf_path)
        if tables:
            print(f"  ✓ Camelot (stream): {len(tables)} tables")
            all_tables.extend(tables)
        
        # Strategy 4: Tabula - Java-backed robust extraction
        tables = self._extract_tabula(pdf_path)
        if tables:
            print(f"  ✓ Tabula: {len(tables)} tables")
            all_tables.extend(tables)
        
        # Strategy 5: pdfplumber with heuristic tuning
        tables = self._extract_pdfplumber(pdf_path)
        if tables:
            print(f"  ✓ pdfplumber: {len(tables)} tables")
            all_tables.extend(tables)
        
        # Remove duplicates and sort by position
        all_tables = self._deduplicate_tables(all_tables)
        
        # Clean and validate each table
        cleaned_tables = []
        for i, table in enumerate(all_tables):
            cleaned = self._clean_table(table)
            if self._is_valid_table(cleaned):
                cleaned_tables.append(cleaned)
        
        print(f"  📊 Total unique tables: {len(cleaned_tables)}")
        
        return cleaned_tables
    
    def _extract_opendataloader(self, pdf_path: Path) -> List[pd.DataFrame]:
        """Extract using OpenDataLoader PDF v2.0 hybrid engine [citation:6]"""
        try:
            from odlpdf import ODLPDF
            
            extractor = ODLPDF()
            result = extractor.extract_tables(str(pdf_path))
            
            tables = []
            if hasattr(result, 'tables'):
                for table in result.tables:
                    if hasattr(table, 'data') and table.data:
                        df = pd.DataFrame(table.data)
                        if not df.empty:
                            tables.append(df)
            return tables
        except ImportError:
            return []
        except Exception as e:
            print(f"    OpenDataLoader error: {e}")
            return []
    
    def _extract_camelot_lattice(self, pdf_path: Path) -> List[pd.DataFrame]:
        """Extract bordered tables using Camelot lattice flavor [citation:7]"""
        try:
            tables = camelot.read_pdf(
                str(pdf_path), 
                pages='all', 
                flavor='lattice',
                line_scale=40,
                copy_text=['v']
            )
            return [t.df for t in tables if not t.df.empty]
        except Exception as e:
            return []
    
    def _extract_camelot_stream(self, pdf_path: Path) -> List[pd.DataFrame]:
        """Extract borderless tables using Camelot stream flavor"""
        try:
            tables = camelot.read_pdf(
                str(pdf_path),
                pages='all',
                flavor='stream',
                row_tol=10,
                strip_text='\n'
            )
            return [t.df for t in tables if not t.df.empty]
        except Exception:
            return []
    
    def _extract_tabula(self, pdf_path: Path) -> List[pd.DataFrame]:
        """Extract using Tabula (Java-based, strong on financial docs) [citation:7]"""
        try:
            tables = tabula.read_pdf(
                str(pdf_path),
                pages='all',
                multiple_tables=True,
                lattice=True,
                guess=False
            )
            return [t for t in tables if not t.empty]
        except Exception:
            return []
    
    def _extract_pdfplumber(self, pdf_path: Path) -> List[pd.DataFrame]:
        """Extract using pdfplumber with optimized settings [citation:7]"""
        tables = []
        
        table_settings = {
            "vertical_strategy": "text",
            "horizontal_strategy": "text",
            "snap_tolerance": 3,
            "join_tolerance": 3,
            "edge_min_length": 10,
            "min_words_vertical": 3,
            "min_words_horizontal": 1,
        }
        
        try:
            with pdfplumber.open(pdf_path) as pdf:
                for page_num, page in enumerate(pdf.pages):
                    page_tables = page.extract_tables(table_settings)
                    for table_data in page_tables:
                        if table_data and len(table_data) > 1:
                            # Convert to DataFrame
                            headers = [str(h).strip() if h else f"Col_{i}" 
                                      for i, h in enumerate(table_data[0])]
                            rows = table_data[1:]
                            df = pd.DataFrame(rows, columns=headers)
                            if not df.empty:
                                tables.append(df)
        except Exception as e:
            pass
        
        return tables
    
    def _deduplicate_tables(self, tables: List[pd.DataFrame]) -> List[pd.DataFrame]:
        """Remove duplicate tables based on content hash"""
        unique_tables = []
        seen_hashes = set()
        
        for table in tables:
            # Create content hash
            content_str = table.to_csv(index=False).encode('utf-8')
            content_hash = hash(content_str)
            
            if content_hash not in seen_hashes:
                seen_hashes.add(content_hash)
                unique_tables.append(table)
        
        return unique_tables
    
    def _clean_table(self, df: pd.DataFrame) -> pd.DataFrame:
        """Clean and normalize extracted table"""
        if df.empty:
            return df
        
        # Remove completely empty rows/columns
        df = df.dropna(how='all')
        df = df.dropna(axis=1, how='all')
        
        # Fill NaN with empty string
        df = df.fillna('')
        
        # Strip whitespace from string cells
        df = df.applymap(lambda x: x.strip() if isinstance(x, str) else x)
        
        # Detect and set header row if needed
        if self.config.preserve_headers and len(df) > 0:
            first_row = df.iloc[0].astype(str)
            # Check if first row looks like headers
            is_likely_header = (
                not first_row.str.contains(r'^\d+\.?\d*$').all() and
                first_row.str.len().mean() < 30
            )
            if is_likely_header:
                df.columns = first_row
                df = df[1:]
        
        return df
    
    def _is_valid_table(self, df: pd.DataFrame) -> bool:
        """Validate if DataFrame represents a real table"""
        if df.empty:
            return False
        
        rows, cols = df.shape
        
        # Minimum size thresholds
        if rows < 2 or cols < 2:
            return False
        
        # Check data density
        total_cells = rows * cols
        non_empty = df.astype(str).applymap(lambda x: len(x) > 0).sum().sum()
        density = non_empty / total_cells if total_cells > 0 else 0
        
        return density > 0.3


