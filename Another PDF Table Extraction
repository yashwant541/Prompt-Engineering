class SpartanTableDetector:
    """
    Heuristic-based table detection using OpenCV
    Based on SPARTAN: Structured Parsing and Relevant Table Analysis
    Achieves 0.93 F1-score without GPU or ML training [citation:2]
    """
    
    def __init__(self):
        self.debug = False
    
    def detect_tables_on_page(self, image: np.ndarray) -> List[Tuple[int, int, int, int]]:
        """
        Detect table regions using classical computer vision
        
        Returns list of bounding boxes (x, y, w, h)
        """
        # Convert to grayscale
        gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
        
        # Adaptive thresholding for robust binarization
        binary = cv2.adaptiveThreshold(
            gray, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, 
            cv2.THRESH_BINARY_INV, 11, 2
        )
        
        # Remove frame lines using Hough transform [citation:10]
        edges = cv2.Canny(binary, 50, 150, apertureSize=3)
        lines = cv2.HoughLinesP(edges, 1, np.pi/180, threshold=100, 
                                minLineLength=100, maxLineGap=10)
        
        if lines is not None:
            # Create mask for frame lines
            mask = np.ones_like(binary) * 255
            for line in lines:
                x1, y1, x2, y2 = line[0]
                # Whitening out long horizontal/vertical lines
                if abs(y2 - y1) < 10 and (x2 - x1) > image.shape[1] * 0.8:
                    cv2.line(mask, (x1, y1), (x2, y2), 0, 5)
                if abs(x2 - x1) < 10 and (y2 - y1) > image.shape[0] * 0.8:
                    cv2.line(mask, (x1, y1), (x2, y2), 0, 5)
            
            binary = cv2.bitwise_and(binary, mask)
        
        # Morphological operations to connect text fragments
        kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
        dilated = cv2.dilate(binary, kernel, iterations=2)
        
        # Find contours (potential table regions)
        contours, _ = cv2.findContours(dilated, cv2.RETR_EXTERNAL, 
                                       cv2.CHAIN_APPROX_SIMPLE)
        
        # Filter and refine bounding boxes
        table_regions = []
        min_table_area = image.shape[0] * image.shape[1] * 0.01  # At least 1% of page
        
        for contour in contours:
            x, y, w, h = cv2.boundingRect(contour)
            area = w * h
            
            # Filter criteria: reasonable size and aspect ratio
            if area > min_table_area and h > 50 and w > 100:
                # Aspect ratio check (not too tall and thin)
                aspect_ratio = w / h if h > 0 else 0
                if 0.3 < aspect_ratio < 10:
                    table_regions.append((x, y, w, h))
        
        # Merge overlapping regions using non-maximum suppression
        merged = self._non_max_suppression(table_regions, iou_threshold=0.3)
        
        return merged
    
    def _non_max_suppression(self, boxes: List[Tuple], iou_threshold: float) -> List[Tuple]:
        """Remove overlapping bounding boxes"""
        if not boxes:
            return []
        
        # Convert to numpy for faster computation
        boxes_array = np.array(boxes)
        x1 = boxes_array[:, 0]
        y1 = boxes_array[:, 1]
        x2 = boxes_array[:, 0] + boxes_array[:, 2]
        y2 = boxes_array[:, 1] + boxes_array[:, 3]
        
        areas = (x2 - x1 + 1) * (y2 - y1 + 1)
        order = areas.argsort()[::-1]
        
        keep = []
        while order.size > 0:
            i = order[0]
            keep.append(i)
            
            xx1 = np.maximum(x1[i], x1[order[1:]])
            yy1 = np.maximum(y1[i], y1[order[1:]])
            xx2 = np.minimum(x2[i], x2[order[1:]])
            yy2 = np.minimum(y2[i], y2[order[1:]])
            
            w = np.maximum(0.0, xx2 - xx1 + 1)
            h = np.maximum(0.0, yy2 - yy1 + 1)
            intersection = w * h
            
            iou = intersection / (areas[i] + areas[order[1:]] - intersection)
            inds = np.where(iou <= iou_threshold)[0]
            order = order[inds + 1]
        
        return boxes_array[keep].tolist()


