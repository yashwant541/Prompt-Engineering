        # Export to Excel
        output_path = "Standard_Chartered_Q1_2026_Financial_Tables.xlsx"
        extractor.export_to_excel(output_path)
        
        print("\n✅ Done!")
        
    except Exception as e:
        print(f"\n❌ Error: {str(e)}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    main()
