                    has_numeric = True
                    break
            if has_numeric:
                data_start = row_idx
                break
        
        # Find data end
        data_end = data_start
        consecutive_empty = 0
        for row_idx in range(data_start, min(data_start + 500, self.analyzer.max_rows + 1)):
            has_data = False
            for col_idx in data_columns:
                if self.analyzer.sheet.cell(row_idx, col_idx).value is not None:
