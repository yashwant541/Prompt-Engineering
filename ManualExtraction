class TableType(Enum):
    """Types of tables that can be detected"""
    FINANCIAL_STATEMENT = "financial_statement"
    PIVOT_TABLE = "pivot_table"
    RAW_DATA = "raw_data"
    HIERARCHICAL = "hierarchical"
    CROSS_TAB = "cross_tabulation"
    MULTI_LEVEL_HEADER = "multi_level_header"
    MULTI_LEVEL_LABEL = "multi_level_label"
    UNKNOWN = "unknown"

@dataclass
class CellRange:
    """Represents a cell range in Excel"""
    start_row: int
    end_row: int
    start_col: int
    end_col: int
    
    def to_excel_range(self) -> str:
        """Convert to Excel range notation (e.g., 'A1:B10')"""
        start_cell = f"{get_column_letter(self.start_col)}{self.start_row}"
        end_cell = f"{get_column_letter(self.end_col)}{self.end_row}"
        return f"{start_cell}:{end_cell}"
    
    def __str__(self):
        return self.to_excel_range()

@dataclass
class TableStructure:
    """Represents the detected structure of a table"""
    header_rows: List[int] = field(default_factory=list)
    data_start_row: int = 0
    data_end_row: int = 0
    data_columns: List[int] = field(default_factory=list)
    label_columns: List[int] = field(default_factory=list)  # Changed to list for multiple label columns
    has_merged_headers: bool = False
    multi_section: bool = False
    sections: Dict[str, Dict] = field(default_factory=dict)
    confidence_score: float = 0.0
    table_type: TableType = TableType.UNKNOWN
    header_levels: List[str] = field(default_factory=list)
    label_hierarchy: Dict[int, str] = field(default_factory=dict)  # Column index -> hierarchy level name
    
    def get_header_range(self) -> CellRange:
        """Get the cell range for headers"""
        if not self.header_rows or not self.data_columns:
            return None
        
        min_row = min(self.header_rows)
        max_row = max(self.header_rows)
        min_col = min(self.data_columns)
        max_col = max(self.data_columns)
        
        return CellRange(min_row, max_row, min_col, max_col)
    
    def get_data_range(self) -> CellRange:
        """Get the cell range for data"""
        if not self.data_start_row or not self.data_end_row or not self.data_columns:
            return None
        
        min_col = min(self.data_columns)
        max_col = max(self.data_columns)
        
        return CellRange(self.data_start_row, self.data_end_row, min_col, max_col)
    
    def get_label_range(self) -> CellRange:
        """Get the cell range for labels"""
        if not self.data_start_row or not self.data_end_row or not self.label_columns:
            return None
        
        min_col = min(self.label_columns)
        max_col = max(self.label_columns)
        
        return CellRange(self.data_start_row, self.data_end_row, min_col, max_col)
    
    def get_label_hierarchy_str(self) -> str:
        """Get string representation of label hierarchy"""
        if not self.label_columns:
            return "None"
        
        hierarchy = []
        for col in self.label_columns:
            level_name = self.label_hierarchy.get(col, f"Level_{len(hierarchy)+1}")
            hierarchy.append(f"{level_name} (Col {get_column_letter(col)})")
        
        return " → ".join(hierarchy)

@dataclass
class ColumnProfile:
    """Profile of a column in the sheet"""
    index: int
    letter: str
    sample_values: List[str]
    data_type: str
    fill_rate: float
    is_numeric: bool
    is_date: bool
    is_header_candidate: bool
    is_data_candidate: bool
    business_meaning: str
    pattern_score: float
    is_label_candidate: bool = False
    label_hierarchy_level: int = 0

@dataclass
class ExtractionSuggestion:
    """Suggestion for table extraction"""
    name: str
    description: str
    confidence: float
    structure: TableStructure
    preview: pd.DataFrame
    pros: List[str]
    cons: List[str]

