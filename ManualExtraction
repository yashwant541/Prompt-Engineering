    """Main execution function"""
    print("="*80)
    print("🧠 ADVANCED SMART TABLE EXTRACTOR WITH MULTI-LEVEL LABELS")
    print("="*80)
    
    file_path = input("\nEnter Excel file path: ").strip().strip('"').strip("'")
    
    if not os.path.exists(file_path):
        print(f"❌ File not found: {file_path}")
        return
    
    configurator = SmartManualConfigurator(file_path)
    
    try:
        configurator.load_workbook()
        structure = configurator.analyze_and_suggest()
        df = configurator.extract_table(structure)
        
        print(f"\n{'='*80}")
