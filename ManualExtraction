    def get_headers_for_preview(self, suggestion: ExtractionSuggestion) -> List[str]:
        """Get headers for preview"""
        if len(suggestion.structure.header_rows) > 1:
            return self.processor.merge_multi_level_headers(
                suggestion.structure.header_rows, 
                suggestion.structure.data_columns
            )
        else:
            headers = []
            header_row = suggestion.structure.header_rows[0]
            for col_idx in suggestion.structure.data_columns:
                header_cell = self.sheet.cell(header_row, col_idx)
                if header_cell.value:
                    headers.append(str(header_cell.value).strip())
                else:
                    headers.append(f"Col_{get_column_letter(col_idx)}")
            return headers
    
    def extract_preview_with_labels(self, headers: List[str], data_start: int, 
                                    data_end: int, data_columns: List[int],
                                    label_columns: List[int]) -> Optional[pd.DataFrame]:
        """Extract preview with specified label columns"""
        try:
            data = []
            hierarchical_labels = []
            
            for row_idx in range(data_start, min(data_end + 1, data_start + 20)):
                row_data = []
                for col_idx in data_columns:
                    cell = self.sheet.cell(row_idx, col_idx)
                    row_data.append(cell.value)
                data.append(row_data)
                
                # Build hierarchical label
                if label_columns:
                    label_parts = []
                    for col_idx in label_columns:
                        label_cell = self.sheet.cell(row_idx, col_idx)
                        if label_cell.value:
                            label_parts.append(str(label_cell.value).strip())
                    
                    if label_parts:
                        hierarchical_labels.append(" → ".join(label_parts))
                    else:
                        hierarchical_labels.append(f"Row_{row_idx}")
                else:
                    hierarchical_labels.append(f"Row_{row_idx}")
            
            df = pd.DataFrame(data, columns=headers[:len(data_columns)])
            df.index = hierarchical_labels
            df.index.name = 'Hierarchical Index'
            
            return df.head(10)
            
        except Exception as e:
            print(f"  ⚠ Preview extraction failed: {e}")
            return None
    
    def show_full_table_preview(self, suggestion: ExtractionSuggestion):
        """Show full table preview with hierarchical labels"""
        print(f"\n{'='*80}")
        print(f"📊 FULL TABLE PREVIEW: {suggestion.name}")
        print(f"{'='*80}")
        
        structure = suggestion.structure
        header_rows = sorted(structure.header_rows)
        data_start = structure.data_start_row
        data_end = structure.data_end_row
        data_columns = structure.data_columns
        label_columns = structure.label_columns
        
        # Merge multi-level headers if needed
        if len(header_rows) > 1:
            headers = self.processor.merge_multi_level_headers(header_rows, data_columns)
            print(f"\n🔗 Merged Headers: {headers}")
        else:
            headers = []
            for col_idx in data_columns:
                header_cell = self.sheet.cell(header_rows[0], col_idx)
                if header_cell.value:
                    headers.append(str(header_cell.value).strip())
                else:
                    headers.append(f"Col_{get_column_letter(col_idx)}")
        
        # Extract data with hierarchical labels
        data = []
        hierarchical_labels = []
        
        for row_idx in range(data_start, data_end + 1):
            row_data = []
            has_data = False
            
            for col_idx in data_columns:
                cell_value = self.sheet.cell(row_idx, col_idx).value
                row_data.append(cell_value)
                if cell_value is not None:
                    has_data = True
            
            if has_data:
                data.append(row_data)
                
                # Build hierarchical label
                if label_columns:
                    label_parts = []
                    for col_idx in label_columns:
                        label_cell = self.sheet.cell(row_idx, col_idx)
                        if label_cell.value:
                            label = str(label_cell.value).strip()
                            # Clean up labels
                            label = re.sub(r'^[A-Z]\*\d+\s*', '', label)
                            label = re.sub(r'^V\*\d+\s*', '', label)
                            label_parts.append(label)
                        else:
                            label_parts.append("")
                    
                    if label_parts:
                        # Remove empty parts and join
                        non_empty_parts = [p for p in label_parts if p]
                        if non_empty_parts:
                            hierarchical_label = " → ".join(non_empty_parts)
                        else:
                            hierarchical_label = f"Row_{row_idx}"
                    else:
                        hierarchical_label = f"Row_{row_idx}"
                else:
                    hierarchical_label = f"Row_{row_idx}"
                
                hierarchical_labels.append(hierarchical_label)
        
        # Create DataFrame with hierarchical index
        df = pd.DataFrame(data, columns=headers[:len(data_columns)])
        df.index = hierarchical_labels
        df.index.name = 'Hierarchical Index'
        
        # Clean up
        df = df.dropna(how='all')
        df = df.dropna(axis=1, how='all')
        
        # Convert numeric columns
        for col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='ignore')
        
        # Display full preview
        print(f"\n📊 Table Shape: {df.shape[0]} rows × {df.shape[1]} columns")
        print(f"\n📋 Full Data Preview (with hierarchical labels):")
        print("-" * 100)
        print(df.to_string())
        print("-" * 100)
        
        # Ask if user wants to export this preview
        export_choice = input("\nExport this table? (y/n): ").strip().lower()
        if export_choice == 'y':
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"preview_{suggestion.name.replace(' ', '_')}_{timestamp}.xlsx"
            with pd.ExcelWriter(filename, engine='openpyxl') as writer:
                df.to_excel(writer, sheet_name=self.sheet_name, index=True)
            print(f"✓ Preview exported to: {filename}")
        
        input("\nPress Enter to continue...")
    
