class SmartManualConfigurator:
    """Smart manual configuration system with multi-level label support"""
    
    def __init__(self, file_path: str):
        self.file_path = file_path
        self.wb = None
        self.sheet = None
        self.sheet_name = None
        self.analyzer = None
        self.suggestions = []
        self.selected_suggestion = None
        self.final_config = None
        self.processor = None
    
    def load_workbook(self, sheet_name: str = None):
        """Load workbook and prepare for analysis"""
        self.wb = openpyxl.load_workbook(self.file_path, data_only=True)
        
        if sheet_name:
            self.sheet = self.wb[sheet_name]
            self.sheet_name = sheet_name
        else:
            self.show_available_sheets()
            choice = input("\nSelect sheet (enter name or number): ").strip()
            
            if choice.isdigit():
                idx = int(choice) - 1
                if 0 <= idx < len(self.wb.sheetnames):
                    self.sheet_name = self.wb.sheetnames[idx]
                    self.sheet = self.wb[self.sheet_name]
            else:
                if choice in self.wb.sheetnames:
                    self.sheet_name = choice
                    self.sheet = self.wb[choice]
                else:
