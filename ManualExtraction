class SuggestionEngine:
    """Generates intelligent suggestions for table extraction"""
    
    def __init__(self, analyzer: SmartAnalyzer):
        self.analyzer = analyzer
        self.analysis = analyzer.analyze_sheet()
        self.processor = MultiLevelProcessor(analyzer.sheet)
    
    def generate_suggestions(self) -> List[ExtractionSuggestion]:
        """Generate multiple extraction suggestions"""
        suggestions = []
        
        standard = self.suggest_standard_table()
        if standard:
            suggestions.append(standard)
        
        multi_level_header = self.suggest_multi_level_table()
        if multi_level_header:
            suggestions.append(multi_level_header)
        
        multi_level_labels = self.suggest_multi_level_labels()
        if multi_level_labels:
            suggestions.append(multi_level_labels)
        
        financial = self.suggest_financial_statement()
        if financial:
            suggestions.append(financial)
        
        simple = self.suggest_simple_range()
        if simple:
            suggestions.append(simple)
        
        suggestions.sort(key=lambda x: x.confidence, reverse=True)
        
        return suggestions
    
    def suggest_multi_level_labels(self) -> Optional[ExtractionSuggestion]:
        """Suggest table with multi-level labels (hierarchical row structure)"""
        print("\n  📊 Analyzing multi-level label pattern...")
        
        # Find header rows
        header_candidates = []
        for profile in self.analysis['row_profiles']:
            if profile['row_type'] == 'header_row' and profile['confidence'] > 0.6:
                header_candidates.append(profile['row_idx'])
        
        if not header_candidates:
            return None
        
        header_row = header_candidates[0]
        
        # Find data columns
        data_columns = []
        for col_profile in self.analysis['column_profiles']:
            if col_profile.is_data_candidate and col_profile.fill_rate > 0.3:
                data_columns.append(col_profile.index)
        
        if not data_columns:
            return None
        
        # Find data start
        data_start = header_row + 1
        for profile in self.analysis['row_profiles']:
            if profile['row_idx'] > header_row and profile['row_type'] in ['data_row', 'label_row']:
                data_start = profile['row_idx']
                break
        
        # Find data end
        data_end = data_start
        for profile in self.analysis['row_profiles']:
            if profile['row_idx'] > data_start and profile['row_type'] == 'empty_row':
                break
            if profile['row_type'] in ['data_row', 'label_row']:
                data_end = profile['row_idx']
        
        # Detect multi-level labels
        label_columns, label_hierarchy = self.processor.detect_multi_level_labels(data_start, data_end)
        
        if not label_columns:
            # If no multi-level labels, use single label column
            label_columns = [self.find_label_column(data_columns)]
            label_hierarchy = {label_columns[0]: "Metric"}
        
        # Merge multi-level headers if multiple header rows exist
        if len(header_candidates) > 1:
            headers = self.processor.merge_multi_level_headers(header_candidates, data_columns)
            header_rows = header_candidates
        else:
            headers = []
            for col_idx in data_columns:
                header_cell = self.analyzer.sheet.cell(header_row, col_idx)
                if header_cell.value:
                    headers.append(str(header_cell.value).strip())
                else:
                    headers.append(f"Col_{get_column_letter(col_idx)}")
            header_rows = [header_row]
        
        # Extract preview with multi-level labels
        preview = self.extract_preview_with_multilevel_labels(
            headers, data_start, data_end, data_columns, label_columns
        )
        
        if preview is None or len(preview) < 2:
            return None
        
        confidence = 0.88
        
        structure = TableStructure(
            header_rows=header_rows,
            data_start_row=data_start,
            data_end_row=data_end,
            data_columns=data_columns,
            label_columns=label_columns,
            label_hierarchy=label_hierarchy,
            has_merged_headers=len(self.analysis['merged_cells']['header_candidates']) > 0,
            multi_section=False,
            confidence_score=confidence,
            table_type=TableType.MULTI_LEVEL_LABEL
        )
        
        return ExtractionSuggestion(
            name="Multi-Level Labels (Hierarchical Rows)",
            description="Table with hierarchical row structure using multiple label columns",
            confidence=confidence,
            structure=structure,
            preview=preview,
            pros=["Preserves hierarchical row structure", "Handles categories and subcategories", "Clean multi-level indexing"],
            cons=["More complex index structure", "May need verification for hierarchy levels"]
        )
    
    def suggest_multi_level_table(self) -> Optional[ExtractionSuggestion]:
        """Suggest table with multi-level headers"""
        print("\n  📊 Analyzing multi-level header pattern...")
        
        # Find potential header rows
        header_candidates = []
        for profile in self.analysis['row_profiles']:
            if profile['row_type'] in ['header_row', 'label_row'] and profile['fill_rate'] > 0.4:
                header_candidates.append(profile['row_idx'])
        
        if len(header_candidates) < 2:
            return None
        
        # Find consecutive header rows
        header_groups = []
        current_group = [header_candidates[0]]
        
        for i in range(1, len(header_candidates)):
            if header_candidates[i] == header_candidates[i-1] + 1:
                current_group.append(header_candidates[i])
            else:
                if len(current_group) >= 2:
                    header_groups.append(current_group)
                current_group = [header_candidates[i]]
        
        if len(current_group) >= 2:
            header_groups.append(current_group)
        
        if not header_groups:
            return None
        
        header_rows = header_groups[0]
        
        # Find data columns
        data_columns = []
        for col_idx in range(1, self.analyzer.max_cols + 1):
            numeric_count = 0
            check_rows = range(max(header_rows) + 2, min(max(header_rows) + 10, self.analyzer.max_rows + 1))
            for row_idx in check_rows:
                cell = self.analyzer.sheet.cell(row_idx, col_idx)
                if isinstance(cell.value, (int, float)):
                    numeric_count += 1
            
            if numeric_count >= 3:
                data_columns.append(col_idx)
        
        if not data_columns:
            return None
        
        # Find data start
        data_start = max(header_rows) + 1
        for row_idx in range(max(header_rows) + 1, min(max(header_rows) + 20, self.analyzer.max_rows + 1)):
            has_numeric = False
            for col_idx in data_columns:
