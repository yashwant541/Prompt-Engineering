    def extract_preview_with_multilevel_labels(self, headers: List[str], data_start: int, 
                                               data_end: int, data_columns: List[int],
                                               label_columns: List[int]) -> Optional[pd.DataFrame]:
        """Extract preview with multi-level labels"""
        try:
            # Extract data
            data = []
            hierarchical_labels = []
            
            for row_idx in range(data_start, min(data_end + 1, data_start + 20)):
                row_data = []
                for col_idx in data_columns:
                    cell = self.analyzer.sheet.cell(row_idx, col_idx)
                    row_data.append(cell.value)
                data.append(row_data)
                
                # Build hierarchical label
                if label_columns:
                    label_parts = []
                    for col_idx in label_columns:
                        label_cell = self.analyzer.sheet.cell(row_idx, col_idx)
                        if label_cell.value:
                            label_parts.append(str(label_cell.value).strip())
                    
                    if label_parts:
                        hierarchical_labels.append(" → ".join(label_parts))
                    else:
                        hierarchical_labels.append(f"Row_{row_idx}")
                else:
                    hierarchical_labels.append(f"Row_{row_idx}")
            
            # Create DataFrame
            df = pd.DataFrame(data, columns=headers[:len(data_columns)])
            df.index = hierarchical_labels
            df.index.name = 'Hierarchical Index'
            
            return df.head(10)
            
        except Exception as e:
            print(f"  ⚠ Preview extraction failed: {e}")
            return None
    
    def find_label_column(self, data_columns: List[int]) -> int:
        """Find the column that contains row labels"""
        min_data_col = min(data_columns) if data_columns else 1
        
        for col_idx in range(1, min_data_col):
            text_count = 0
            for row_idx in range(1, min(30, self.analyzer.sheet.max_row + 1)):
                cell = self.analyzer.sheet.cell(row_idx, col_idx)
                if cell.value and isinstance(cell.value, str) and len(str(cell.value).strip()) > 0:
                    text_count += 1
            
            if text_count > 10:
                return col_idx
        
        return min_data_col if min_data_col > 1 else 1
    
    def calculate_table_confidence(self, header_row: int, data_columns: List[int], 
                                  preview: pd.DataFrame) -> float:
        """Calculate confidence score for a table structure"""
        confidence = 0.5
        
        if data_columns:
            header_cell = self.analyzer.sheet.cell(header_row, data_columns[0])
            if header_cell.value:
                header_str = str(header_cell.value).lower()
                if re.search(r'fy\d{4}|20\d{2}', header_str):
                    confidence += 0.2
                if any(word in header_str for word in ['actual', 'baseline', 'forecast']):
                    confidence += 0.1
        
        if len(data_columns) >= 3:
            confidence += 0.1
        
        if preview is not None and len(preview) > 0:
            null_ratio = preview.isna().sum().sum() / (len(preview) * len(preview.columns))
            if null_ratio < 0.3:
                confidence += 0.1
            elif null_ratio < 0.5:
                confidence += 0.05
        
        for col in data_columns:
            for col_profile in self.analysis['column_profiles']:
                if col_profile.index == col and col_profile.pattern_score > 0.7:
                    confidence += 0.05
                    break
        
        return min(confidence, 1.0)

