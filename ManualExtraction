class MultiLevelProcessor:
    """Process multi-level headers and labels"""
    
    def __init__(self, sheet):
        self.sheet = sheet
    
    def detect_multi_level_labels(self, data_start: int, data_end: int, 
                                  max_label_cols: int = 5) -> Tuple[List[int], Dict[int, str]]:
        """
        Detect multi-level label columns (like Category, Subcategory, Metric)
        Returns: (list of label columns, dict of column -> hierarchy level name)
        """
        label_columns = []
        label_hierarchy = {}
        
        # Check columns to the left of potential data
        for col_idx in range(1, max_label_cols + 1):
            # Analyze this column for label characteristics
            text_count = 0
            numeric_count = 0
            unique_values = set()
            empty_count = 0
            
            for row_idx in range(data_start, min(data_end + 1, data_start + 50)):
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value:
                    val_str = str(cell.value).strip()
                    unique_values.add(val_str)
                    
                    # Check if it's text (likely a label)
                    if isinstance(cell.value, str) and not re.match(r'[\d\.]+', val_str):
                        text_count += 1
                    elif isinstance(cell.value, (int, float)):
                        numeric_count += 1
                else:
                    empty_count += 1
            
            total_checked = text_count + numeric_count + empty_count
            fill_rate = (text_count + numeric_count) / total_checked if total_checked > 0 else 0
            text_ratio = text_count / (text_count + numeric_count) if (text_count + numeric_count) > 0 else 0
            
            # Column is a good label candidate if:
            # 1. High fill rate (> 40%)
            # 2. Mostly text (> 70% text)
            # 3. Not too many unique values (not a data column)
            if fill_rate > 0.4 and text_ratio > 0.7:
                label_columns.append(col_idx)
                
                # Determine hierarchy level based on position and content
                if col_idx == 1:
                    hierarchy_level = "Category"
                elif col_idx == 2:
                    hierarchy_level = "Subcategory"
                else:
                    hierarchy_level = f"Level_{len(label_columns)}"
                
                label_hierarchy[col_idx] = hierarchy_level
        
        # If no labels found, try to detect from patterns
        if not label_columns:
            # Look for columns with repeating text patterns
            for col_idx in range(1, max_label_cols + 1):
                pattern_detected = self.detect_label_pattern(col_idx, data_start, data_end)
                if pattern_detected:
                    label_columns.append(col_idx)
                    label_hierarchy[col_idx] = f"Label_{col_idx}"
        
        return label_columns, label_hierarchy
    
    def detect_label_pattern(self, col_idx: int, data_start: int, data_end: int) -> bool:
        """Detect if column has label-like patterns (repeating categories)"""
        values = []
        for row_idx in range(data_start, min(data_end + 1, data_start + 30)):
            cell = self.sheet.cell(row_idx, col_idx)
            if cell.value:
                values.append(str(cell.value).strip())
        
        if len(values) < 3:
            return False
        
        # Check for repeating patterns (like sections in financial statements)
        unique_values = set(values)
        repeat_ratio = len(values) / len(unique_values) if unique_values else 0
        
        # If values repeat frequently, it's likely a label column
        if repeat_ratio > 2.0:
            return True
        
        # Check if values look like categories
        category_keywords = ['assets', 'liabilities', 'equity', 'income', 'expense', 'total']
        if any(keyword in ' '.join(values).lower() for keyword in category_keywords):
            return True
        
        return False
    
    def merge_multi_level_labels(self, label_columns: List[int], 
                                 data_start: int, data_end: int) -> Tuple[List[str], List[str]]:
        """
        Merge multiple label columns into hierarchical index
        Returns: (list of merged labels, list of individual label columns names)
        """
        if not label_columns:
            return [], []
        
        merged_labels = []
        column_names = []
        
        # Get column names for labels (from first data row or header)
        for col_idx in label_columns:
            # Try to find column name from header rows
            col_name = None
            for row_idx in range(1, min(data_start, 6)):
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value:
                    col_name = str(cell.value).strip()
                    break
            
            if not col_name:
                col_name = f"Level_{get_column_letter(col_idx)}"
            
            column_names.append(col_name)
        
        # Merge labels for each data row
        for row_idx in range(data_start, data_end + 1):
            label_parts = []
            for col_idx in label_columns:
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value:
                    label_parts.append(str(cell.value).strip())
                else:
                    label_parts.append("")
            
            # Create hierarchical label
            if label_parts:
                # Remove empty parts and join
                non_empty_parts = [p for p in label_parts if p]
                if non_empty_parts:
                    merged_label = " → ".join(non_empty_parts)
                else:
                    merged_label = f"Row_{row_idx}"
            else:
                merged_label = f"Row_{row_idx}"
            
            merged_labels.append(merged_label)
        
        return merged_labels, column_names
    
    def merge_multi_level_headers(self, header_rows: List[int], data_columns: List[int]) -> List[str]:
        """Merge multi-level headers into single header strings"""
        if len(header_rows) <= 1:
            return None
        
        sorted_header_rows = sorted(header_rows)
        
        # Extract all header levels
        header_levels = []
        for row_idx in sorted_header_rows:
            level = []
            for col_idx in data_columns:
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value:
                    level.append(str(cell.value).strip())
                else:
                    # Check for merged cells that span multiple columns
                    merged_value = self.get_merged_header_value(row_idx, col_idx, data_columns)
                    level.append(merged_value)
            header_levels.append(level)
        
        # Merge headers from different levels
        merged_headers = []
        for col_idx in range(len(data_columns)):
            header_parts = []
            
            for level_idx, level in enumerate(header_levels):
                if col_idx < len(level) and level[col_idx]:
                    header_parts.append(level[col_idx])
            
            if header_parts:
                merged = self.intelligently_merge_headers(header_parts)
                merged_headers.append(merged)
            else:
                merged_headers.append(f"Column_{get_column_letter(data_columns[col_idx])}")
        
        return merged_headers
    
    def get_merged_header_value(self, row_idx: int, col_idx: int, data_columns: List[int]) -> str:
        """Get value from merged cell that spans multiple columns"""
        cell = self.sheet.cell(row_idx, col_idx)
        
        for merged_range in self.sheet.merged_cells.ranges:
            if cell.coordinate in merged_range:
                top_left = self.sheet.cell(merged_range.min_row, merged_range.min_col)
                if top_left.value:
                    return str(top_left.value).strip()
        
        return None
    
    def intelligently_merge_headers(self, header_parts: List[str]) -> str:
        """Intelligently merge header parts with appropriate formatting"""
        if not header_parts:
            return ""
        
        header_parts = [h for h in header_parts if h]
        
        if len(header_parts) == 1:
            return header_parts[0]
        
        # Special case: Check if this looks like "Actual" + "FY2022"
        if len(header_parts) == 2:
            if re.match(r'FY\d{4}|20\d{2}', header_parts[1]):
                return f"{header_parts[0]}_{header_parts[1]}"
            
            if any(word in header_parts[0].lower() for word in ['actual', 'baseline', 'forecast', 'budget']):
                return f"{header_parts[0]}_{header_parts[1]}"
        
        # General case: join with underscore
        return "_".join(header_parts)
    
    def detect_section_headers(self, header_rows: List[int], data_columns: List[int]) -> Dict[str, List[int]]:
        """Detect section headers like 'Actual' and 'Baseline' that span multiple columns"""
        if not header_rows:
            return {}
        
        sections = {}
        first_header_row = min(header_rows)
        
        current_section = None
        section_start_col = None
        
        for col_idx in data_columns:
            cell = self.sheet.cell(first_header_row, col_idx)
            if cell.value:
                cell_value = str(cell.value).strip()
                
                if any(keyword in cell_value.lower() for keyword in ['actual', 'baseline', 'forecast', 'budget']):
                    if current_section:
                        sections[current_section] = list(range(section_start_col, col_idx))
                    current_section = cell_value
                    section_start_col = col_idx
        
        if current_section and section_start_col:
            sections[current_section] = list(range(section_start_col, data_columns[-1] + 1))
        
        return sections

