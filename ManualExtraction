class SmartAnalyzer:
    """Advanced analyzer that understands table structures"""
    
    def __init__(self, sheet, max_rows_analysis: int = 100, max_cols_analysis: int = 30):
        self.sheet = sheet
        self.max_rows = min(max_rows_analysis, sheet.max_row)
        self.max_cols = min(max_cols_analysis, sheet.max_column)
        self.cache = {}
        self.multi_processor = MultiLevelProcessor(sheet)
    
    def analyze_sheet(self) -> Dict:
        """Perform comprehensive analysis of the sheet"""
        print("\n🔍 Analyzing sheet structure...")
        
        analysis = {
            'dimensions': self.analyze_dimensions(),
            'density_map': self.analyze_density(),
            'column_profiles': self.analyze_columns(),
            'row_profiles': self.analyze_rows(),
            'merged_cells': self.analyze_merged_cells(),
            'patterns': self.analyze_patterns(),
            'data_types': self.analyze_data_types(),
            'structure_hints': self.analyze_structure_hints()
        }
        
        total_cells = analysis['dimensions']['total_cells']
        print(f"✓ Analysis complete: {total_cells} cells analyzed")
        return analysis
    
    def analyze_dimensions(self) -> Dict:
        """Analyze sheet dimensions"""
        return {
            'total_rows': self.sheet.max_row,
            'total_cols': self.sheet.max_column,
            'used_rows': self.get_used_row_count(),
            'used_cols': self.get_used_col_count(),
            'density': self.calculate_overall_density(),
            'total_cells': self.sheet.max_row * self.sheet.max_column
        }
    
    def analyze_density(self) -> Dict:
        """Analyze data density in the sheet"""
        density_map = []
        for row_idx in range(1, min(50, self.sheet.max_row + 1)):
            row_density = []
            for col_idx in range(1, min(30, self.sheet.max_column + 1)):
                if self.sheet.cell(row_idx, col_idx).value is not None:
                    row_density.append(1)
                else:
                    row_density.append(0)
            density_map.append(row_density)
        
        flat_density = [cell for row in density_map for cell in row]
        total_cells = len(flat_density)
        filled_cells = sum(flat_density)
        
        return {
            'map': density_map,
            'shape': (len(density_map), len(density_map[0]) if density_map else 0),
            'overall_density': filled_cells / total_cells if total_cells > 0 else 0,
            'filled_cells': filled_cells,
            'total_cells': total_cells
        }
    
    def get_used_row_count(self) -> int:
        """Get number of rows with any data"""
        used = 0
        for row_idx in range(1, min(500, self.sheet.max_row + 1)):
            for col_idx in range(1, min(20, self.sheet.max_column + 1)):
                if self.sheet.cell(row_idx, col_idx).value is not None:
                    used += 1
                    break
        return used
    
    def get_used_col_count(self) -> int:
        """Get number of columns with any data"""
        used = 0
        for col_idx in range(1, min(50, self.sheet.max_column + 1)):
            for row_idx in range(1, min(100, self.sheet.max_row + 1)):
                if self.sheet.cell(row_idx, col_idx).value is not None:
                    used += 1
                    break
        return used
    
    def calculate_overall_density(self) -> float:
        """Calculate overall data density"""
        total_cells = 0
        filled_cells = 0
        
        for row_idx in range(1, min(100, self.sheet.max_row + 1)):
            for col_idx in range(1, min(20, self.sheet.max_column + 1)):
                total_cells += 1
                if self.sheet.cell(row_idx, col_idx).value is not None:
                    filled_cells += 1
        
        return filled_cells / total_cells if total_cells > 0 else 0
    
    def analyze_columns(self) -> List[ColumnProfile]:
        """Create detailed profiles for each column"""
        profiles = []
        
        for col_idx in range(1, self.max_cols + 1):
            col_letter = get_column_letter(col_idx)
            values = []
            numeric_count = 0
            text_count = 0
            date_count = 0
            empty_count = 0
            
            sample_values = []
            for row_idx in range(1, min(20, self.max_rows + 1)):
                cell = self.sheet.cell(row_idx, col_idx)
                value = cell.value
                if value is not None and str(value).strip():
                    values.append(value)
                    sample_values.append(str(value)[:30])
                    
                    if isinstance(value, (int, float)):
                        numeric_count += 1
                    elif isinstance(value, str):
                        if re.match(r'\d{1,2}[/-]\d{1,2}[/-]\d{2,4}', value):
                            date_count += 1
                            sample_values[-1] = f"[DATE] {value}"
                        else:
                            text_count += 1
                else:
                    empty_count += 1
            
            total = len(values) + empty_count
            fill_rate = len(values) / total if total > 0 else 0
            
            if numeric_count > text_count and numeric_count > date_count:
                data_type = 'numeric'
                is_numeric = True
                is_date = False
            elif date_count > text_count:
                data_type = 'date'
                is_numeric = False
                is_date = True
            elif text_count > 0:
                data_type = 'text'
                is_numeric = False
                is_date = False
            else:
                data_type = 'empty'
                is_numeric = False
                is_date = False
            
            is_header_candidate = self.is_header_column(col_idx, data_type, values)
            is_data_candidate = not is_header_candidate and fill_rate > 0.3
            business_meaning = self.infer_business_meaning(col_idx, data_type, values)
            pattern_score = self.calculate_column_pattern_score(col_idx, values)
            
            profiles.append(ColumnProfile(
                index=col_idx,
                letter=col_letter,
                sample_values=sample_values[:5],
                data_type=data_type,
                fill_rate=fill_rate,
                is_numeric=is_numeric,
                is_date=is_date,
                is_header_candidate=is_header_candidate,
                is_data_candidate=is_data_candidate,
                business_meaning=business_meaning,
                pattern_score=pattern_score
            ))
        
        return profiles
    
    def is_header_column(self, col_idx: int, data_type: str, values: List) -> bool:
        """Check if column looks like headers"""
        for val in values[:10]:
            val_str = str(val)
            if re.search(r'FY\d{4}|20\d{2}', val_str):
                return True
        
        text_count = sum(1 for v in values if isinstance(v, str) and not re.match(r'[\d\.]+', v))
        if len(values) > 0 and text_count / len(values) > 0.7:
            return True
        
        return False
    
    def infer_business_meaning(self, col_idx: int, data_type: str, values: List) -> str:
        """Infer business meaning from column content"""
        if not values:
            return "unknown"
        
        header_text = ""
        for row_idx in range(1, min(5, self.max_rows + 1)):
            cell = self.sheet.cell(row_idx, col_idx)
            if cell.value:
                header_text += str(cell.value).lower() + " "
        
        term_map = {
            'revenue': ['revenue', 'income', 'sales', 'turnover'],
            'expense': ['expense', 'cost', 'spending', 'overhead'],
            'profit': ['profit', 'earnings', 'margin', 'net'],
            'asset': ['asset', 'property', 'equipment', 'inventory'],
            'liability': ['liability', 'debt', 'loan', 'payable'],
            'equity': ['equity', 'capital', 'reserve', 'share'],
            'date': ['date', 'year', 'month', 'quarter', 'fy'],
            'percentage': ['%', 'percent', 'rate'],
            'quantity': ['qty', 'count', 'units', 'volume']
        }
        
        for meaning, keywords in term_map.items():
            if any(keyword in header_text for keyword in keywords):
                return meaning
        
        if data_type == 'numeric':
            return 'numeric_value'
        elif data_type == 'date':
            return 'date'
        elif data_type == 'text':
            sample_str = ' '.join([str(v).lower() for v in values[:5]])
            for meaning, keywords in term_map.items():
                if any(keyword in sample_str for keyword in keywords):
                    return meaning
        
        return "unknown"
    
    def calculate_column_pattern_score(self, col_idx: int, values: List) -> float:
        """Calculate how well column follows a pattern"""
        if len(values) < 3:
            return 0.0
        
        score = 0
        
        formats = []
        for v in values[:20]:
            if isinstance(v, (int, float)):
                formats.append('numeric')
            elif isinstance(v, str):
                if v.isdigit():
                    formats.append('digit_string')
                elif re.match(r'[\d,]+\.?\d*', v):
                    formats.append('formatted_number')
                else:
                    formats.append('text')
        
        if formats:
            most_common = Counter(formats).most_common(1)[0]
            score += most_common[1] / len(formats) * 0.5
        
        if len(values) >= 3:
            numeric_values = []
            for v in values[:10]:
                try:
                    num = float(v) if isinstance(v, (int, float)) else float(re.sub(r'[^\d\.-]', '', str(v)))
                    numeric_values.append(num)
                except:
                    pass
            
            if len(numeric_values) >= 3:
                diffs = [numeric_values[i+1] - numeric_values[i] for i in range(len(numeric_values)-1)]
                if diffs and all(abs(d - diffs[0]) < 0.1 for d in diffs):
                    score += 0.3
        
        return min(score, 1.0)
    
    def analyze_rows(self) -> List[Dict]:
        """Analyze row patterns"""
        row_profiles = []
        
        for row_idx in range(1, min(50, self.max_rows + 1)):
            values = []
            data_types = []
            merged_info = []
            
            for col_idx in range(1, self.max_cols + 1):
                cell = self.sheet.cell(row_idx, col_idx)
                value = cell.value
                values.append(value)
                
                is_merged = False
                for merged_range in self.sheet.merged_cells.ranges:
                    if cell.coordinate in merged_range:
                        is_merged = True
                        merged_info.append(merged_range)
                        break
                
                if value is not None:
                    if isinstance(value, (int, float)):
                        data_types.append('numeric')
                    elif isinstance(value, str):
                        if re.match(r'FY\d{4}|20\d{2}', value):
                            data_types.append('fiscal_year')
                        else:
                            data_types.append('text')
                else:
                    data_types.append('empty')
            
            non_empty = sum(1 for v in values if v is not None)
            fill_rate = non_empty / len(values) if values else 0
            
            if fill_rate > 0.7 and 'fiscal_year' in data_types:
                row_type = 'header_row'
                confidence = 0.9
            elif fill_rate > 0.5 and 'numeric' in data_types:
                row_type = 'data_row'
                confidence = 0.8
            elif fill_rate < 0.2:
                row_type = 'empty_row'
                confidence = 0.9
            elif fill_rate > 0.3 and 'text' in data_types:
                row_type = 'label_row'
                confidence = 0.7
            else:
                row_type = 'mixed_row'
                confidence = 0.5
            
            row_profiles.append({
                'row_idx': row_idx,
                'non_empty': non_empty,
                'fill_rate': fill_rate,
                'data_types': data_types,
                'row_type': row_type,
                'confidence': confidence,
                'has_merged': len(merged_info) > 0
            })
        
        return row_profiles
    
    def analyze_merged_cells(self) -> Dict:
        """Analyze merged cell patterns"""
        merged_info = {
            'count': len(self.sheet.merged_cells.ranges),
            'ranges': [],
            'header_candidates': []
        }
        
        for merged_range in self.sheet.merged_cells.ranges:
            merged_info['ranges'].append({
                'min_row': merged_range.min_row,
                'max_row': merged_range.max_row,
                'min_col': merged_range.min_col,
                'max_col': merged_range.max_col,
                'size_rows': merged_range.max_row - merged_range.min_row + 1,
                'size_cols': merged_range.max_col - merged_range.min_col + 1
            })
            
            if merged_range.min_row <= 5:
                merged_info['header_candidates'].append(merged_range)
        
        return merged_info
    
    def analyze_patterns(self) -> Dict:
        """Detect patterns in the sheet"""
        patterns = {
            'fiscal_years': [],
            'totals': [],
            'section_headers': [],
            'empty_separators': []
        }
        
        for row_idx in range(1, self.max_rows + 1):
            row_text = []
            for col_idx in range(1, min(10, self.max_cols + 1)):
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value:
                    row_text.append(str(cell.value).lower())
            
            row_text_str = ' '.join(row_text)
            
            if re.search(r'fy\d{4}|20\d{2}', row_text_str):
                patterns['fiscal_years'].append(row_idx)
            
            if re.search(r'total|sum|合计', row_text_str):
                patterns['totals'].append(row_idx)
            
            if re.search(r'^(assets|liabilities|equity|income|expense)', row_text_str):
                patterns['section_headers'].append(row_idx)
        
        for row_idx in range(1, self.max_rows + 1):
            empty_count = 0
            for col_idx in range(1, self.max_cols + 1):
                if self.sheet.cell(row_idx, col_idx).value is None:
                    empty_count += 1
            
            if empty_count > self.max_cols * 0.8:
                patterns['empty_separators'].append(row_idx)
        
        return patterns
    
    def analyze_data_types(self) -> Dict:
        """Analyze data type distribution"""
        type_distribution = {
            'numeric': 0,
            'text': 0,
            'date': 0,
            'empty': 0,
            'fiscal_year': 0
        }
        
        for row_idx in range(1, min(100, self.max_rows + 1)):
            for col_idx in range(1, min(20, self.max_cols + 1)):
                cell = self.sheet.cell(row_idx, col_idx)
                if cell.value is None:
                    type_distribution['empty'] += 1
                elif isinstance(cell.value, (int, float)):
                    type_distribution['numeric'] += 1
                elif isinstance(cell.value, str):
                    if re.match(r'FY\d{4}|20\d{2}', cell.value):
                        type_distribution['fiscal_year'] += 1
                    elif re.match(r'\d{1,2}[/-]\d{1,2}[/-]\d{2,4}', cell.value):
                        type_distribution['date'] += 1
                    else:
                        type_distribution['text'] += 1
        
        return type_distribution
    
    def analyze_structure_hints(self) -> Dict:
        """Find structural hints that indicate table boundaries"""
        hints = {
            'possible_headers': [],
            'possible_data_starts': [],
            'possible_tables': []
        }
        
        row_profiles = self.analyze_rows()
        
        for profile in row_profiles:
            if profile['row_type'] == 'header_row' and profile['confidence'] > 0.7:
                hints['possible_headers'].append(profile['row_idx'])
        
        for i, profile in enumerate(row_profiles):
            if i > 0 and profile['row_type'] == 'data_row':
                prev_profile = row_profiles[i-1]
                if prev_profile['row_type'] in ['empty_row', 'header_row']:
                    hints['possible_data_starts'].append(profile['row_idx'])
        
        return hints

