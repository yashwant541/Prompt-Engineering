            data_columns = list(range(1, min(10, self.sheet.max_column + 1)))
        
        # Ask for label columns (NEW)
        print("\n🏷️  LABEL COLUMNS SELECTION:")
        print("   Label columns are used as row identifiers (e.g., Metric names, Categories)")
        print("   You can select multiple columns for hierarchical labels (e.g., Category, Subcategory)")
        print("   Example: 'A' for single label column")
        print("   Example: 'A,B' for multi-level labels")
        
        label_input = input("Enter label columns (comma-separated, e.g., 'A' or 'A,B'): ").strip().upper()
        
        if label_input:
            label_columns = []
            label_hierarchy = {}
            
            for i, col in enumerate(label_input.split(',')):
                col = col.strip()
                if col.isalpha():
                    col_idx = column_index_from_string(col)
                    label_columns.append(col_idx)
                    
                    if i == 0:
                        hierarchy_level = "Category"
                    elif i == 1:
                        hierarchy_level = "Subcategory"
                    else:
                        hierarchy_level = f"Level_{i+1}"
                    
                    label_hierarchy[col_idx] = hierarchy_level
        else:
            # Auto-detect label columns
            label_columns = [1]  # Default to first column
            label_hierarchy = {1: "Metric"}
        
        # Show the range that will be extracted
        min_data_col = min(data_columns)
        max_data_col = max(data_columns)
        
        print(f"\n📌 Extracting:")
        if len(header_rows) > 1:
            print(f"   • Multi-level headers: Rows {header_rows}, Columns {get_column_letter(min_data_col)}-{get_column_letter(max_data_col)}")
        else:
            print(f"   • Headers: Row {header_rows[0]}, Columns {get_column_letter(min_data_col)}-{get_column_letter(max_data_col)}")
        
        print(f"   • Data: Rows {data_start}-?, Columns {get_column_letter(min_data_col)}-{get_column_letter(max_data_col)}")
        print(f"   • Label columns: {[get_column_letter(c) for c in label_columns]} → {structure.get_label_hierarchy_str() if 'structure' in locals() else 'Hierarchical labels'}")
        
        confirm = input("\nProceed with this configuration? (y/n): ").strip().lower()
        if confirm != 'y':
            return self.manual_configuration()
        
        return TableStructure(
            header_rows=header_rows,
            data_start_row=data_start,
            data_end_row=self.detect_data_end_from_config(data_start, data_columns),
            data_columns=data_columns,
            label_columns=label_columns,
            label_hierarchy=label_hierarchy,
            has_merged_headers=False,
            multi_section=False,
            confidence_score=0.5,
            table_type=TableType.UNKNOWN
        )
    
    def display_sheet_preview(self, max_rows: int = 20, max_cols: int = 15):
        """Display sheet preview"""
        print(f"\n📊 Sheet Preview: {self.sheet_name}")
        print("=" * 100)
        
        max_show_rows = min(max_rows, self.sheet.max_row)
        max_show_cols = min(max_cols, self.sheet.max_column)
        
        print("    ", end="")
        for col_idx in range(1, max_show_cols + 1):
            col_letter = get_column_letter(col_idx)
            print(f"{col_letter:^8}", end="")
        print()
        
        print("    ", end="")
        for _ in range(max_show_cols):
            print("--------", end="")
        print()
        
        for row_idx in range(1, max_show_rows + 1):
            print(f"{row_idx:3} |", end="")
            for col_idx in range(1, max_show_cols + 1):
                cell = self.sheet.cell(row_idx, col_idx)
                value = cell.value
                
                if value is None:
                    display_value = ""
                else:
                    value_str = str(value).strip()
                    if len(value_str) > 7:
                        display_value = value_str[:5] + "..."
                    else:
                        display_value = value_str
                
                for merged_range in self.sheet.merged_cells.ranges:
                    if cell.coordinate in merged_range:
                        display_value = f"[{display_value}]"
                        break
                
                print(f"{display_value:^8}", end="")
            print()
        
        print("=" * 100)
    
    def detect_data_end_from_config(self, data_start: int, data_columns: List[int]) -> int:
        """Detect data end for manual config"""
        last_row = data_start
        consecutive_empty = 0
        
        for row_idx in range(data_start, min(data_start + 500, self.sheet.max_row + 1)):
            has_data = False
            for col_idx in data_columns:
                if self.sheet.cell(row_idx, col_idx).value is not None:
                    has_data = True
                    break
            
            if has_data:
                last_row = row_idx
                consecutive_empty = 0
            else:
                consecutive_empty += 1
                if consecutive_empty >= 3:
                    break
        
        return last_row
    
    def extract_table(self, structure: TableStructure) -> pd.DataFrame:
        """Extract the final table with multi-level labels"""
        print(f"\n{'='*80}")
        print("📊 EXTRACTING TABLE")
        print(f"{'='*80}")
        
        print(f"\n📌 Extracting from ranges:")
        header_range = structure.get_header_range()
        data_range = structure.get_data_range()
        if header_range:
            print(f"   • Headers: {header_range}")
        if data_range:
            print(f"   • Data: {data_range}")
        
        print(f"   • Label columns: {[get_column_letter(c) for c in structure.label_columns]} → {structure.get_label_hierarchy_str()}")
        
        header_rows = sorted(structure.header_rows)
        data_start = structure.data_start_row
        data_end = structure.data_end_row
        data_columns = structure.data_columns
        label_columns = structure.label_columns
        
        # Merge multi-level headers if there are multiple header rows
        if len(header_rows) > 1:
            print(f"\n🔗 Merging {len(header_rows)} header rows...")
            headers = self.processor.merge_multi_level_headers(header_rows, data_columns)
            print(f"   Merged headers: {headers}")
        else:
            headers = []
            for col_idx in data_columns:
                header_cell = self.sheet.cell(header_rows[0], col_idx)
                if header_cell.value:
                    headers.append(str(header_cell.value).strip())
                else:
                    headers.append(f"Col_{get_column_letter(col_idx)}")
        
        # Extract data with hierarchical labels
        data = []
        hierarchical_labels = []
        
        print(f"\n📊 Extracting data with hierarchical labels...")
        
        for row_idx in range(data_start, data_end + 1):
            row_data = []
            has_data = False
            
            for col_idx in data_columns:
                cell_value = self.sheet.cell(row_idx, col_idx).value
                row_data.append(cell_value)
                if cell_value is not None:
                    has_data = True
            
            if has_data:
                data.append(row_data)
                
                # Build hierarchical label
                if label_columns:
                    label_parts = []
                    for col_idx in label_columns:
                        label_cell = self.sheet.cell(row_idx, col_idx)
                        if label_cell.value:
                            label = str(label_cell.value).strip()
                            # Clean up labels
                            label = re.sub(r'^[A-Z]\*\d+\s*', '', label)
                            label = re.sub(r'^V\*\d+\s*', '', label)
                            label_parts.append(label)
                        else:
                            label_parts.append("")
                    
                    if label_parts:
                        # Remove empty parts and join
                        non_empty_parts = [p for p in label_parts if p]
                        if non_empty_parts:
                            hierarchical_label = " → ".join(non_empty_parts)
                        else:
                            hierarchical_label = f"Row_{row_idx}"
                    else:
                        hierarchical_label = f"Row_{row_idx}"
                else:
                    hierarchical_label = f"Row_{row_idx}"
                
                hierarchical_labels.append(hierarchical_label)
        
        # Create DataFrame with hierarchical index
        df = pd.DataFrame(data, columns=headers[:len(data_columns)])
        df.index = hierarchical_labels
        df.index.name = 'Hierarchical Index'
        
        # Clean up
        df = df.dropna(how='all')
        df = df.dropna(axis=1, how='all')
        
        # Convert numeric columns
        for col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='ignore')
        
        print(f"\n✓ Table extracted: {len(df)} rows × {len(df.columns)} columns")
        print(f"✓ Hierarchical index created with {len(label_columns)} level(s)")
        print(f"✓ Headers: {list(df.columns)}")
        
        return df
    
    def save_table(self, df: pd.DataFrame, output_format: str = 'excel', output_path: str = None):
        """Save extracted table"""
        if output_path is None:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            output_path = f"extracted_{self.sheet_name}_{timestamp}"
        
        if output_format == 'excel':
            output_file = f"{output_path}.xlsx"
            with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
                df.to_excel(writer, sheet_name=self.sheet_name, index=True)
            print(f"\n✓ Saved to: {output_file}")
        
        elif output_format == 'csv':
            output_file = f"{output_path}.csv"
            df.to_csv(output_file)
            print(f"\n✓ Saved to: {output_file}")
        
        elif output_format == 'both':
            excel_file = f"{output_path}.xlsx"
            csv_file = f"{output_path}.csv"
            with pd.ExcelWriter(excel_file, engine='openpyxl') as writer:
                df.to_excel(writer, sheet_name=self.sheet_name, index=True)
            df.to_csv(csv_file)
            print(f"\n✓ Saved to: {excel_file} and {csv_file}")
    
    def close(self):
        """Close workbook"""
        if self.wb:
            self.wb.close()

