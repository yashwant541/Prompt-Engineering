    def get_header_preview(self, suggestion: ExtractionSuggestion) -> str:
        """Get a preview of how headers will be merged"""
        if len(suggestion.structure.header_rows) <= 1:
            return "Single header row (no merging needed)"
        
        header_rows = sorted(suggestion.structure.header_rows)
        data_columns = suggestion.structure.data_columns
        
        merged_headers = self.processor.merge_multi_level_headers(header_rows, data_columns)
        
        if merged_headers:
            preview = ", ".join(merged_headers[:5])
            if len(merged_headers) > 5:
                preview += f", ... ({len(merged_headers)} total)"
            return preview
        
        return "Unable to preview headers"
    
