import pandas as pd
import openpyxl
from openpyxl.utils import get_column_letter
import re
from typing import List, Dict, Optional, Tuple, Any

class AdvancedExcelTableExtractor:
    def __init__(self, file_path: str):
        self.file_path = file_path
        self.wb = None
        
    def load_workbook(self):
        """Load workbook with data_only=True to get calculated values"""
        self.wb = openpyxl.load_workbook(self.file_path, data_only=True)
        
    def close_workbook(self):
        """Close workbook to free memory"""
        if self.wb:
            self.wb.close()
    
    def find_header_row_and_columns(self, sheet) -> Tuple[int, List[int], int]:
        """
        Find header row, data columns, and label column.
        Returns (header_row_index, data_columns_list, label_column_index)
        """
        fiscal_year_pattern = re.compile(r'FY\d{4}|20\d{2}')
        
        # First, find the header row (contains fiscal years)
        header_row_idx = None
        data_columns = []
        
        for row_idx in range(min(20, sheet.max_row)):
            fiscal_years_found = []
            potential_data_cols = []
            
            for col_idx in range(1, min(sheet.max_column + 1, 20)):
                cell_value = sheet.cell(row_idx + 1, col_idx).value
                if cell_value is not None:
                    cell_str = str(cell_value).strip()
                    
                    # Check for fiscal year patterns
                    if fiscal_year_pattern.search(cell_str) or (cell_str.isdigit() and len(cell_str) == 4 and int(cell_str) >= 2000):
                        fiscal_years_found.append((col_idx, cell_str))
                        potential_data_cols.append(col_idx)
            
            # If we found at least 3 fiscal years, this is our header row
            if len(fiscal_years_found) >= 3:
                header_row_idx = row_idx
                data_columns = potential_data_cols
                break
        
        if header_row_idx is None:
            # Fallback: find row with most numeric-looking values
            max_score = 0
            for row_idx in range(min(20, sheet.max_row)):
                score = 0
                potential_cols = []
                for col_idx in range(1, min(sheet.max_column + 1, 20)):
                    cell_value = sheet.cell(row_idx + 1, col_idx).value
                    if cell_value is not None:
                        cell_str = str(cell_value).strip()
                        if re.match(r'\d{4}', cell_str):
                            score += 2
                            potential_cols.append(col_idx)
                        elif cell_str.replace(',', '').replace('.', '').isdigit():
                            score += 1
                if score > max_score:
                    max_score = score
                    header_row_idx = row_idx
                    data_columns = potential_cols
        
        # Find label column (where row descriptions are stored)
        label_column = None
        if header_row_idx is not None:
            # Check columns to the left of data columns
            min_data_col = min(data_columns) if data_columns else 1
            for col_idx in range(1, min_data_col):
                # Check if this column has text values
                text_count = 0
                for row_idx in range(header_row_idx + 1, min(header_row_idx + 30, sheet.max_row)):
                    cell_value = sheet.cell(row_idx + 1, col_idx).value
                    if cell_value is not None and str(cell_value).strip():
                        cell_str = str(cell_value).strip()
                        # If it's not purely numeric, it might be a label
                        if not cell_str.replace(',', '').replace('.', '').isdigit():
                            text_count += 1
                
                if text_count > 3:  # Found multiple text entries
                    label_column = col_idx
                    break
            
            # If no label column found, use the first column before data columns
            if label_column is None and min_data_col > 1:
                label_column = min_data_col - 1
        
        return header_row_idx, data_columns, label_column
    
    def extract_continuous_table(self, sheet, header_row_idx: int, data_columns: List[int], 
                                 label_column: int, start_row: int) -> Tuple[List[str], List[List[Any]], int]:
        """
        Extract a continuous block of table data starting from start_row
        Returns (row_labels, data_rows, last_row_processed)
        """
        row_labels = []
        data_rows = []
        current_row = start_row
        
        while current_row < sheet.max_row:
            # Check if this row has any data in the data columns
            has_data = False
            row_values = []
            
            for col_idx in data_columns:
                cell_value = sheet.cell(current_row + 1, col_idx).value
                if cell_value is not None and str(cell_value).strip():
                    has_data = True
                    row_values.append(cell_value)
                else:
                    row_values.append(None)
            
            # Get label if available
            label = None
            if label_column and label_column > 0:
                label_cell = sheet.cell(current_row + 1, label_column).value
                if label_cell is not None:
                    label = str(label_cell).strip()
            
            # If this row has data, add it
            if has_data:
                if label:
                    row_labels.append(label)
                else:
                    row_labels.append(f"Row_{len(row_labels) + 1}")
                data_rows.append(row_values)
                current_row += 1
            else:
                # Check if we've hit the end of this table section
                # If we found a blank row and we've already collected data, break
                if len(data_rows) > 0:
                    # Check if next row might be a new section header
                    next_row_has_fiscal_years = False
                    if current_row + 1 < sheet.max_row:
                        for col_idx in data_columns:
                            next_cell = sheet.cell(current_row + 2, col_idx).value
                            if next_cell is not None:
                                next_str = str(next_cell).strip()
                                if re.match(r'FY\d{4}|20\d{2}', next_str):
                                    next_row_has_fiscal_years = True
                                    break
                    
                    # If next row has fiscal years, we've reached a new section header
                    if next_row_has_fiscal_years:
                        break
                    # Otherwise, it's just a separator, continue to next row
                    else:
                        current_row += 1
                else:
                    current_row += 1
        
        return row_labels, data_rows, current_row
    
    def extract_table(self, sheet_name: str, header_row: Optional[int] = None) -> pd.DataFrame:
        """
        Extract table from a specific sheet, handling multiple sections
        """
        if not self.wb:
            self.load_workbook()
        
        sheet = self.wb[sheet_name]
        
        # Find header row and columns
        if header_row is None:
            header_row_idx, data_columns, label_column = self.find_header_row_and_columns(sheet)
        else:
            header_row_idx = header_row - 1
            # Determine data columns from header row
            data_columns = []
            for col_idx in range(1, min(sheet.max_column + 1, 20)):
                cell_value = sheet.cell(header_row_idx + 1, col_idx).value
                if cell_value is not None:
                    data_columns.append(col_idx)
            # Find label column
            label_column = None
            min_data_col = min(data_columns) if data_columns else 1
            for col_idx in range(1, min_data_col):
                if sheet.cell(header_row_idx + 2, col_idx).value is not None:
                    label_column = col_idx
                    break
        
        print(f"  Header row: {header_row_idx + 1}")
        print(f"  Data columns: {data_columns}")
        print(f"  Label column: {label_column + 1 if label_column else 'Not found'}")
        
        if not data_columns:
            raise ValueError(f"No data columns found in sheet '{sheet_name}'")
        
        # Extract headers
        headers = []
        for col_idx in data_columns:
            header_cell = sheet.cell(header_row_idx + 1, col_idx).value
            if header_cell is None:
                header_cell = f"Year_{col_idx}"
            headers.append(str(header_cell).strip())
        
        # Find where data starts (after header row)
        data_start_row = header_row_idx + 1
        while data_start_row < sheet.max_row:
            has_data = False
            for col_idx in data_columns:
                cell_value = sheet.cell(data_start_row + 1, col_idx).value
                if cell_value is not None and str(cell_value).strip():
                    has_data = True
                    break
            if has_data:
                break
            data_start_row += 1
        
        # Extract all table sections
        all_row_labels = []
        all_data_rows = []
        current_row = data_start_row
        
        # Keep extracting until we've processed all data rows
        while current_row < sheet.max_row:
            labels, rows, next_row = self.extract_continuous_table(
                sheet, header_row_idx, data_columns, label_column, current_row
            )
            
            if rows:  # If we found data in this section
                all_row_labels.extend(labels)
                all_data_rows.extend(rows)
            
            current_row = next_row + 1  # Move to next row after the processed section
            
            # If we've reached the end or next row is beyond sheet, break
            if current_row >= sheet.max_row:
                break
            
            # Check if we've hit a new section with its own sub-header
            next_cell = sheet.cell(current_row + 1, data_columns[0]).value if data_columns else None
            if next_cell and str(next_cell).strip() and re.match(r'FY\d{4}|20\d{2}', str(next_cell).strip()):
                # This is a new section header, update header_row_idx
                header_row_idx = current_row
                # Update headers if needed
                new_headers = []
                for col_idx in data_columns:
                    header_cell = sheet.cell(header_row_idx + 1, col_idx).value
                    if header_cell:
                        new_headers.append(str(header_cell).strip())
                if new_headers:
                    headers = new_headers
                current_row += 1
        
        # Create DataFrame
        df = pd.DataFrame(all_data_rows, columns=headers)
        
        # Add row labels as index
        if all_row_labels:
            df.index = all_row_labels
            df.index.name = 'Metric'
        
        # Clean up: remove completely empty rows
        df = df.dropna(how='all')
        
        # Convert numeric columns
        for col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='ignore')
        
        return df
    
    def extract_all_tables(self, sheets_to_read: Optional[List[str]] = None) -> Dict[str, pd.DataFrame]:
        """
        Extract tables from specified sheets or all sheets
        """
        if not self.wb:
            self.load_workbook()
        
        results = {}
        
        # Determine which sheets to process
        if sheets_to_read is None:
            sheets_to_read = self.wb.sheetnames
        
        for sheet_name in sheets_to_read:
            if sheet_name in self.wb.sheetnames:
                try:
                    print(f"\n{'='*60}")
                    print(f"Processing sheet: {sheet_name}")
                    print(f"{'='*60}")
                    df = self.extract_table(sheet_name)
                    
                    if not df.empty:
                        results[sheet_name] = df
                        print(f"\n✓ Successfully extracted table:")
                        print(f"  - {len(df)} rows")
                        print(f"  - {len(df.columns)} columns: {list(df.columns)}")
                        print(f"\nPreview:")
                        print(df.head(10))
                    else:
                        print(f"⚠ No data extracted from sheet '{sheet_name}'")
                        
                except Exception as e:
                    print(f"✗ Error processing sheet '{sheet_name}': {str(e)}")
                    import traceback
                    traceback.print_exc()
        
        return results
    
    def save_tables(self, tables: Dict[str, pd.DataFrame], output_format: str = 'excel', 
                   output_path: str = 'extracted_tables'):
        """
        Save extracted tables to file(s)
        """
        if output_format == 'excel':
            with pd.ExcelWriter(f"{output_path}.xlsx", engine='openpyxl') as writer:
                for sheet_name, df in tables.items():
                    clean_name = sheet_name[:31].replace('/', '_').replace('\\', '_')
                    df.to_excel(writer, sheet_name=clean_name)
            print(f"\n✓ Saved all tables to {output_path}.xlsx")
        
        elif output_format == 'csv':
            for sheet_name, df in tables.items():
                clean_name = sheet_name.replace(' ', '_').replace('/', '_').replace('\\', '_')
                filename = f"{output_path}_{clean_name}.csv"
                df.to_csv(filename)
                print(f"✓ Saved {filename}")

