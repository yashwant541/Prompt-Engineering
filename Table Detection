if __name__ == "__main__":
    file_path = "Dummy_Financials.xlsx"
    
    # Create extractor
    extractor = ComplexExcelTableExtractor(file_path)
    
    try:
        # Extract all tables
        all_tables = extractor.extract_all_tables()
        
