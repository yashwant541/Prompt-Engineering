import pandas as pd
import openpyxl
from openpyxl.utils import get_column_letter
import re
from typing import List, Dict, Optional, Tuple, Any
from collections import defaultdict

class ComplexExcelTableExtractor:
    def __init__(self, file_path: str):
        self.file_path = file_path
        self.wb = None
        
    def load_workbook(self):
        """Load workbook with data_only=True to get calculated values"""
        self.wb = openpyxl.load_workbook(self.file_path, data_only=True)
        
    def close_workbook(self):
        """Close workbook to free memory"""
        if self.wb:
            self.wb.close()
    
    def find_multi_level_headers(self, sheet) -> Tuple[List[int], Dict[int, List[int]], Dict[int, str]]:
        """
        Find multi-level headers and group them by section.
        Returns: (header_rows, {section_start_col: data_columns}, {col: header_text})
        """
        fiscal_year_pattern = re.compile(r'FY\d{4}|20\d{2}')
        header_rows = []
        
        # First, find all rows that contain fiscal years
        for row_idx in range(min(30, sheet.max_row)):
            has_fiscal_years = False
            for col_idx in range(1, min(sheet.max_column + 1, 20)):
                cell_value = sheet.cell(row_idx + 1, col_idx).value
                if cell_value is not None:
                    cell_str = str(cell_value).strip()
                    if fiscal_year_pattern.search(cell_str) or (cell_str.isdigit() and len(cell_str) == 4 and int(cell_str) >= 2000):
                        has_fiscal_years = True
                        break
            if has_fiscal_years:
                header_rows.append(row_idx)
        
        # Group columns by sections (based on empty columns)
        sections = {}
        current_section_start = 1
        section_headers = {}
        
        if header_rows:
            # Use the first header row to determine column grouping
            header_row_idx = header_rows[0]
            
            for col_idx in range(1, min(sheet.max_column + 1, 20)):
                cell_value = sheet.cell(header_row_idx + 1, col_idx).value
                if cell_value is None or str(cell_value).strip() == '':
                    # Empty column might indicate section break
                    if col_idx > current_section_start:
                        sections[current_section_start] = list(range(current_section_start, col_idx))
                    current_section_start = col_idx + 1
                else:
                    # Store header text
                    section_headers[col_idx] = str(cell_value).strip()
            
            # Add the last section
            if current_section_start <= sheet.max_column:
                sections[current_section_start] = list(range(current_section_start, min(sheet.max_column + 1, 20)))
        
        return header_rows, sections, section_headers
    
    def extract_row_labels(self, sheet, data_start_row: int, data_end_row: int, 
                          label_column: int = 1) -> List[str]:
        """
        Extract row labels from the specified column
        """
        labels = []
        for row_idx in range(data_start_row, data_end_row + 1):
            cell_value = sheet.cell(row_idx + 1, label_column).value
            if cell_value is not None:
                label = str(cell_value).strip()
                # Clean up labels - remove prefixes like "V*02" if they exist
                label = re.sub(r'^V\*\d+\s*', '', label)
                labels.append(label if label else f"Row_{row_idx}")
            else:
                labels.append(f"Row_{row_idx}")
        return labels
    
    def extract_section_data(self, sheet, header_row_idx: int, data_columns: List[int],
                            start_row: int, section_name: str = "") -> Tuple[pd.DataFrame, int]:
        """
        Extract data for a specific section (e.g., Actual or Baseline)
        """
        # Extract headers for this section
        headers = []
        for col_idx in data_columns:
            header_cell = sheet.cell(header_row_idx + 1, col_idx).value
            if header_cell is None:
                header_cell = f"Col_{col_idx}"
            headers.append(f"{section_name}_{str(header_cell).strip()}" if section_name else str(header_cell).strip())
        
        # Find where data starts
        data_start = start_row
        while data_start < sheet.max_row:
            has_data = False
            for col_idx in data_columns:
                cell_value = sheet.cell(data_start + 1, col_idx).value
                if cell_value is not None and str(cell_value).strip():
                    has_data = True
                    break
            if has_data:
                break
            data_start += 1
        
        # Extract data
        data_rows = []
        row_labels = []
        current_row = data_start
        
        while current_row < sheet.max_row:
            # Check if this row has data in any of the data columns
            has_data = False
            row_values = []
            
            for col_idx in data_columns:
                cell_value = sheet.cell(current_row + 1, col_idx).value
                if cell_value is not None and str(cell_value).strip():
                    has_data = True
                    row_values.append(cell_value)
                else:
                    row_values.append(None)
            
            # Get row label from column A or B
            label_cell = sheet.cell(current_row + 1, 1).value  # Column A
            if label_cell is None or not str(label_cell).strip():
                label_cell = sheet.cell(current_row + 1, 2).value  # Column B
            
            if has_data:
                if label_cell:
                    label = str(label_cell).strip()
                    # Clean up label
                    label = re.sub(r'^V\*\d+\s*', '', label)
                    row_labels.append(label)
                else:
                    row_labels.append(f"Row_{current_row}")
                data_rows.append(row_values)
                current_row += 1
            else:
                # If we've collected data and hit an empty row, stop this section
                if len(data_rows) > 0:
                    break
                current_row += 1
        
        if data_rows:
            df = pd.DataFrame(data_rows, columns=headers)
            df.index = row_labels
            df.index.name = 'Metric'
            return df, current_row
        
        return pd.DataFrame(), current_row
    
    def extract_table(self, sheet_name: str) -> Dict[str, pd.DataFrame]:
        """
        Extract table from a specific sheet, handling multiple sections (Actual vs Baseline)
        """
        if not self.wb:
            self.load_workbook()
        
        sheet = self.wb[sheet_name]
        
        # Find header rows and sections
        header_rows, sections, section_headers = self.find_multi_level_headers(sheet)
        
        print(f"  Found header rows at: {[h+1 for h in header_rows]}")
        print(f"  Found sections: {sections}")
        
        if not header_rows:
            raise ValueError(f"No header rows found in sheet '{sheet_name}'")
        
        # Determine section names (Actual, Baseline, etc.)
        section_names = {}
        for col_idx, header_text in section_headers.items():
            # Look for section indicators like "Actual" or "Baseline"
            if 'actual' in header_text.lower():
                for start_col, cols in sections.items():
                    if col_idx in cols:
                        section_names[start_col] = 'Actual'
            elif 'baseline' in header_text.lower():
                for start_col, cols in sections.items():
                    if col_idx in cols:
                        section_names[start_col] = 'Baseline'
        
        # Extract each section
        results = {}
        data_start_row = max(header_rows) + 1
        
        for start_col, cols in sections.items():
            section_name = section_names.get(start_col, f"Section_{start_col}")
            print(f"\n  Extracting section: {section_name} (Columns: {cols})")
            
            # Use the appropriate header row (if multiple, use the one with years)
            header_row_idx = header_rows[-1] if header_rows else header_rows[0]
            
            df, last_row = self.extract_section_data(sheet, header_row_idx, cols, 
                                                     data_start_row, section_name)
            
            if not df.empty:
                results[section_name] = df
                print(f"    ✓ Extracted {len(df)} rows")
                data_start_row = last_row
            else:
                print(f"    ⚠ No data found")
        
        # If we have both Actual and Baseline, merge them
        if 'Actual' in results and 'Baseline' in results:
            print("\n  Merging Actual and Baseline sections...")
            merged_df = pd.concat([results['Actual'], results['Baseline']], axis=1)
            # Remove duplicate index names if any
            merged_df = merged_df.loc[~merged_df.index.duplicated(keep='first')]
            results['Combined'] = merged_df
            print(f"    ✓ Created combined table with {len(merged_df)} rows and {len(merged_df.columns)} columns")
        
        return results
    
    def extract_all_tables(self, sheets_to_read: Optional[List[str]] = None) -> Dict[str, Dict[str, pd.DataFrame]]:
        """
        Extract tables from specified sheets or all sheets
        """
        if not self.wb:
            self.load_workbook()
        
        results = {}
        
        # Determine which sheets to process
        if sheets_to_read is None:
            sheets_to_read = self.wb.sheetnames
        
        for sheet_name in sheets_to_read:
            if sheet_name in self.wb.sheetnames:
                try:
                    print(f"\n{'='*80}")
                    print(f"Processing sheet: {sheet_name}")
                    print(f"{'='*80}")
                    
                    sheet_results = self.extract_table(sheet_name)
                    
                    if sheet_results:
                        results[sheet_name] = sheet_results
                        
                        # Display preview
                        for section_name, df in sheet_results.items():
                            print(f"\n  {section_name} Section Preview:")
                            print(df.head(8))
                            print(f"  Shape: {df.shape}")
                    else:
                        print(f"⚠ No data extracted from sheet '{sheet_name}'")
                        
                except Exception as e:
                    print(f"✗ Error processing sheet '{sheet_name}': {str(e)}")
                    import traceback
                    traceback.print_exc()
        
        return results
    
    def save_tables(self, tables: Dict[str, Dict[str, pd.DataFrame]], output_path: str = 'extracted_tables'):
        """
        Save extracted tables to Excel file with multiple sheets
        """
        with pd.ExcelWriter(f"{output_path}.xlsx", engine='openpyxl') as writer:
            for sheet_name, sections in tables.items():
                for section_name, df in sections.items():
                    # Create sheet name
                    sheet_title = f"{sheet_name}_{section_name}"[:31]
                    sheet_title = sheet_title.replace('/', '_').replace('\\', '_').replace(':', '_')
                    df.to_excel(writer, sheet_name=sheet_title)
        
        print(f"\n✓ Saved all tables to {output_path}.xlsx")

