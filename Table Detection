if __name__ == "__main__":
    file_path = "Dummy_Financials.xlsx"
    
    # Create extractor
    extractor = AdvancedExcelTableExtractor(file_path)
    
    try:
        # Extract all tables
        tables = extractor.extract_all_tables()
        
        # Display detailed results
        for sheet_name, df in tables.items():
            print(f"\n{'='*80}")
