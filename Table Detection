        # Save to Excel
        if tables:
            extractor.save_tables(tables, output_format='excel', output_path='extracted_financials')
            
            # Also save as CSV for individual files
            extractor.save_tables(tables, output_format='csv', output_path='extracted_financials')
        
    finally:
        extractor.close_workbook()
