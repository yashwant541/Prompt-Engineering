#!/usr/bin/env python3
"""
Production-Grade Financial PDF Table Extractor (v2)
- Multi-strategy extraction
- CV-based table detection (ACTIVE)
- Region-based extraction
- Table scoring + deduplication
- Multi-page table stitching
- Financial data cleaning
"""

import os
import json
import pandas as pd
import numpy as np
from pathlib import Path
import fitz  # PyMuPDF
import cv2
from PIL import Image
import io
import camelot
import pdfplumber
import tabula
from dataclasses import dataclass
from typing import List, Tuple
import hashlib
import shutil

# ================= CONFIG =================

@dataclass
class Config:
    output_formats: List[str] = None

    def __post_init__(self):
        if self.output_formats is None:
            self.output_formats = ['csv']

# ================= CV DETECTOR =================

class CVTableDetector:
    def detect(self, image):
        gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
        binary = cv2.adaptiveThreshold(gray,255,cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
                                       cv2.THRESH_BINARY_INV,11,2)
        kernel = cv2.getStructuringElement(cv2.MORPH_RECT,(5,5))
        dilated = cv2.dilate(binary,kernel,iterations=2)
        contours,_ = cv2.findContours(dilated,cv2.RETR_EXTERNAL,cv2.CHAIN_APPROX_SIMPLE)

        boxes=[]
        h_img,w_img=image.shape[:2]
        for c in contours:
            x,y,w,h = cv2.boundingRect(c)
            if w*h > 0.01*w_img*h_img and w>100 and h>50:
                boxes.append((x,y,w,h))
        return boxes

# ================= CORE =================

class Extractor:

    def __init__(self):
        self.detector = CVTableDetector()

    def pdf_to_images(self,pdf_path):
        doc = fitz.open(pdf_path)
        images=[]
        for page in doc:
            pix = page.get_pixmap()
            img = Image.open(io.BytesIO(pix.tobytes()))
            images.append(np.array(img))
        return images

    def detect_regions(self,pdf_path):
        images = self.pdf_to_images(pdf_path)
        all_regions = {}
        for i,img in enumerate(images):
            boxes = self.detector.detect(img)
            regions=[]
            for (x,y,w,h) in boxes:
                regions.append(f"{x},{y},{x+w},{y+h}")
            all_regions[i+1]=regions
        return all_regions

    def extract_camelot(self,pdf_path,regions):
        tables=[]
        for page,areas in regions.items():
            if not areas: continue
            try:
                t = camelot.read_pdf(pdf_path,pages=str(page),flavor='stream',table_areas=areas)
                tables.extend([tb.df for tb in t])
            except:
                pass
        return tables

    def extract_pdfplumber(self,pdf_path):
        tables=[]
        with pdfplumber.open(pdf_path) as pdf:
            for p in pdf.pages:
                t = p.extract_tables()
                for tb in t:
                    if tb:
                        df=pd.DataFrame(tb)
                        tables.append(df)
        return tables

    def extract_tabula(self,pdf_path):
        if not shutil.which("java"):
            return []
        try:
            return tabula.read_pdf(pdf_path,pages='all',multiple_tables=True)
        except:
            return []

    def clean_financial(self,df):
        df = df.dropna(how='all').dropna(axis=1,how='all')
        df = df.fillna('')

        def convert(x):
            if isinstance(x,str):
                x=x.strip()
                if x.startswith('(') and x.endswith(')'):
                    x = '-' + x[1:-1]
                x=x.replace(',','')
            return x

        df = df.applymap(convert)
        return df

    def score(self,df):
        if df.empty: return 0
        density = (df!='').sum().sum()/(df.shape[0]*df.shape[1])
        return density

    def dedup(self,tables):
        unique={}
        for df in tables:
            h = hashlib.md5(df.to_csv(index=False).encode()).hexdigest()
            score = self.score(df)
            if h not in unique or unique[h][1] < score:
                unique[h]=(df,score)
        return [v[0] for v in unique.values()]

    def stitch(self,tables):
        stitched=[]
        prev=None
        for df in tables:
            if prev is not None and list(df.columns)==list(prev.columns):
                prev = pd.concat([prev,df])
            else:
                if prev is not None:
                    stitched.append(prev)
                prev=df
        if prev is not None:
            stitched.append(prev)
        return stitched

    def run(self,pdf_path,output_dir="output"):
        Path(output_dir).mkdir(exist_ok=True)

        regions = self.detect_regions(pdf_path)

        tables=[]
        tables += self.extract_camelot(pdf_path,regions)
        tables += self.extract_pdfplumber(pdf_path)
        tables += self.extract_tabula(pdf_path)

        tables = [self.clean_financial(t) for t in tables]
        tables = self.dedup(tables)
        tables = self.stitch(tables)

        for i,t in enumerate(tables):
            t.to_csv(f"{output_dir}/table_{i+1}.csv",index=False)
            print(f"Saved table {i+1} shape={t.shape}")

        print(f"Total tables: {len(tables)}")

# ================= RUN =================

if __name__ == "__main__":
    extractor = Extractor()
    extractor.run("standard-chartered-plc-full-year-2025-press-release.pdf")
